# =====================================================
# Образец .env — скопируйте в .env и заполните.
# Файл .env НЕ коммитится (см. .gitignore).
# =====================================================

# Flask
SECRET_KEY=replace-with-long-random-string
FLASK_ENV=production

# PostgreSQL
POSTGRES_USER=dsp
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=dsp

# TTL токенов шифрования (часы)
TOKEN_TTL_HOURS=24
